<Window x:Class="WheelerPhotoParlour.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="惠勒照相馆 Wheeler Photo Parlour" 
        Height="680" Width="1150" 
        MinHeight="520" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource AppWindow}"
        Loaded="OnLoaded" Closed="OnClosed" KeyDown="OnWindowKeyDown">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,0,0,3" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo和标题 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Image x:Name="LogoImage" Width="32" Height="32" Margin="0,0,10,0"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           UseLayoutRounding="True" SnapsToDevicePixels="True"/>
                    <TextBlock x:Name="AppTitleText" Style="{StaticResource TitleText}" Text="惠勒照相馆" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 语言切换 + 关于按钮：固定最小宽度，避免被挤没 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="LangBtn" Content="EN" MinWidth="50" Padding="14,8"
                            Style="{StaticResource AppButton}" Click="OnLangClick" Margin="0,0,10,0"/>
                    <Button x:Name="AboutBtn" Content="📜 本馆信誉" MinWidth="110"
                            Style="{StaticResource AppButton}" Click="OnAboutClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧照片列表 -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 列表标题 -->
                    <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="PhotoListTitleText" Text="马背上的相机袋" Foreground="{StaticResource AccentBrush}" 
                                       FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="1" x:Name="SelectAllCheck" 
                                      Content="全选" Foreground="{StaticResource AccentBrush}" FontSize="13"
                                      VerticalAlignment="Center" Click="OnSelectAllClick"
                                      Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                    <!-- 照片列表 -->
                    <ListBox Grid.Row="1" x:Name="PhotoList" 
                             Style="{StaticResource AppListBox}"
                             ItemContainerStyle="{StaticResource AppListBoxItem}"
                             SelectionChanged="OnPhotoSelected"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Cursor="Hand" MouseLeftButtonDown="OnThumbClick">
                                        <Image Source="{Binding Thumbnail}" 
                                               Width="240" Height="135" 
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="LowQuality"/>
                                        <!-- 勾选高亮边框：仅在已勾选时显示 -->
                                        <Border BorderBrush="{StaticResource AccentBrush}" BorderThickness="4"
                                                Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <!-- 勾选标记：仅在已勾选时显示 -->
                                        <Border Background="{StaticResource AccentBrush}" CornerRadius="10"
                                                Width="26" Height="26"
                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Margin="6"
                                                Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="✓" FontSize="15" FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Text="{Binding FileName}" 
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,5,0,0" HorizontalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 分隔线 -->
            <Border Grid.Column="1" Width="3" Background="{StaticResource PrimaryBrush}" Margin="5,0"/>

            <!-- 右侧预览区域 -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="5,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 预览 -->
                    <Border Grid.Row="0" Background="{StaticResource BackgroundBrush}" Margin="5">
                        <Grid>
                            <!-- 空状态 -->
                            <StackPanel x:Name="EmptyPanel" 
                                        VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="📷" FontSize="64" HorizontalAlignment="Center" 
                                           Foreground="{StaticResource PrimaryDarkBrush}"/>
                                <TextBlock x:Name="EmptyPreviewText" Text="请从左侧相机袋中，挑一张底片瞧瞧" 
                                           Foreground="{StaticResource TextSecondaryBrush}" 
                                           FontSize="16" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>

                            <!-- 加载中 -->
                            <StackPanel x:Name="LoadingPanel" 
                                        VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Visibility="Collapsed">
                                <TextBlock x:Name="LoadingText" Text="🧪 正在暗房中用银盐工艺冲洗照片，请勿关闭电源..." 
                                           Foreground="{StaticResource AccentBrush}" FontSize="16"/>
                            </StackPanel>

                            <!-- 图片预览 -->
                            <Image x:Name="PhotoPreview" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                    <!-- 当前照片信息 -->
                    <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" 
                            BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,2,0,0" Padding="10">
                        <Grid>
                            <TextBlock x:Name="PhotoInfoText" 
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                                       Text="尚未挑选任何底片" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="PhotoSizeText" 
                                       Foreground="{StaticResource AccentBrush}" FontSize="13"
                                       Text="" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- 底部工具栏：分两行，避免按钮和状态文字互相挤压 -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,3,0,0" Padding="15,10">
            <StackPanel>
                <!-- 第一行：照片计数 + 状态文字 -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="PhotoCountText" 
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" 
                               VerticalAlignment="Center" Text="相机袋里共有 0 张底片" Margin="0,0,20,0"/>
                    <TextBlock Grid.Column="1" x:Name="SelectedCountText" 
                               Foreground="{StaticResource AccentBrush}" FontSize="14" FontWeight="Bold"
                               VerticalAlignment="Center" Text="" Margin="0,0,20,0"/>
                    <TextBlock Grid.Column="2" x:Name="StatusText" 
                               Foreground="{StaticResource AccentBrush}" FontSize="13"
                               VerticalAlignment="Center" HorizontalAlignment="Right"
                               TextTrimming="CharacterEllipsis"
                               Text="镜头已擦亮，恭候您的差遣"/>
                </Grid>

                <!-- 第二行：操作按钮，自动换行避免溢出 -->
                <WrapPanel Orientation="Horizontal">
                    <Button x:Name="ExportAllBtn" Content="📦 打包付梓" MinWidth="120"
                            ToolTip="打包付梓，批量冲印（批量导出选中的照片）"
                            Style="{StaticResource PrimaryButton}"
                            Click="OnExportAllClick" IsEnabled="False" Margin="0,0,8,8"/>
                    <Button x:Name="ExportCheckedBtn" Content="📑 自选冲印" MinWidth="120"
                            ToolTip="自选冲印（从相机袋中勾选想要的底片，再打包或逐帧导出）"
                            Style="{StaticResource AppButton}"
                            Click="OnExportCheckedClick" IsEnabled="False" Margin="0,0,8,8"/>
                    <Button x:Name="ExportSelectedBtn" Content="🖨️ 冲印此帧" MinWidth="110"
                            ToolTip="冲印此帧（导出当前选中的这一张照片）"
                            Style="{StaticResource AppButton}"
                            Click="OnExportSelectedClick" IsEnabled="False" Margin="0,0,8,8"/>
                    <Button x:Name="DeleteBtn" Content="🧹 焚毁此帧" MinWidth="110"
                            ToolTip="焚毁此帧（删除当前选中的这一张照片，移至回收站）"
                            Style="{StaticResource AppButton}"
                            Click="OnDeleteClick" IsEnabled="False" Margin="0,0,8,8"/>
                    <Button x:Name="RefreshBtn" Content="🔍 搜寻相机袋" MinWidth="130"
                            ToolTip="搜寻马背上的相机袋（一键全自动扫描）"
                            Style="{StaticResource AppButton}"
                            Click="OnRefreshClick" Margin="0,0,8,8"/>
                    <Button x:Name="SelectSourceBtn" Content="📁 翻看账本" MinWidth="120"
                            ToolTip="翻看其他账本（手动选择存档路径）"
                            Style="{StaticResource AppButton}"
                            Click="OnSelectSourceClick" Margin="0,0,8,8"/>
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
