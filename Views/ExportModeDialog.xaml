<Window x:Class="WheelerPhotoParlour.Views.ExportModeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="请示下"
        Width="430" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource AppWindow}"
        Loaded="OnLoaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="30">
            <TextBlock x:Name="TitleText" Foreground="{StaticResource AccentBrush}" FontSize="17" FontWeight="Bold"
                       Text="请示下" Margin="0,0,0,30" TextWrapping="Wrap"/>

            <RadioButton x:Name="ZipRadio" IsChecked="True" GroupName="ExportMode"
                         Foreground="{StaticResource TextBrush}" FontSize="15"
                         Margin="0,0,0,25" Content="装订成一册"/>

            <RadioButton x:Name="FolderRadio" GroupName="ExportMode"
                         Foreground="{StaticResource TextBrush}" FontSize="15"
                         Margin="0,0,0,10" Content="逐帧冲印"/>

            <CheckBox x:Name="GroupByLocationCheck" IsChecked="True"
                      Foreground="{StaticResource TextBrush}" FontSize="14"
                      Margin="0,15,0,0" Content="按拍摄地点分类整理"
                      ToolTip="把同一地点拍的照片归到同一个文件夹里"/>

            <!-- 时间戳来源选择 -->
            <TextBlock x:Name="TimestampLabel" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                       Margin="0,20,0,8" Text="时间戳来源"/>
            <StackPanel Margin="0,0,0,0">
                <RadioButton x:Name="TimestampRealRadio" IsChecked="True" GroupName="TimestampMode"
                             Foreground="{StaticResource TextBrush}" FontSize="14"
                             Margin="0,0,0,6" Content="真实世界时间"
                             ToolTip="使用从文件中解析出的真实拍摄时间作为文件名中的时间戳"/>
                <RadioButton x:Name="TimestampGameRadio" GroupName="TimestampMode"
                             Foreground="{StaticResource TextBrush}" FontSize="14"
                             Margin="0,0,0,0" Content="游戏内时间"
                             ToolTip="使用游戏故事年代的时间作为文件名中的时间戳"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,3,0,0" Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="OkBtn" Content="就这么办" Style="{StaticResource PrimaryButton}"
                        Click="OnOkClick" Margin="0,0,15,0"/>
                <Button x:Name="CancelBtn" Content="且容我三思" Style="{StaticResource AppButton}"
                        Click="OnCancelClick"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
