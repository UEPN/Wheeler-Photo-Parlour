<Window x:Class="WheelerPhotoParlour.Views.ExportModeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="请示下" 
        Width="430" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource AppWindow}"
        Loaded="OnLoaded">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="30">
            <TextBlock x:Name="TitleText" Foreground="{StaticResource AccentBrush}" FontSize="17" FontWeight="Bold" 
                       Text="请示下" Margin="0,0,0,30" TextWrapping="Wrap"/>
            
            <RadioButton x:Name="ZipRadio" IsChecked="True" GroupName="ExportMode" 
                         Foreground="{StaticResource TextBrush}" FontSize="15"
                         Margin="0,0,0,25" Content="装订成一册"/>
            
            <RadioButton x:Name="FolderRadio" GroupName="ExportMode"
                         Foreground="{StaticResource TextBrush}" FontSize="15"
                         Margin="0,0,0,10" Content="逐帧冲印"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,3,0,0" Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="OkBtn" Content="就这么办" Style="{StaticResource PrimaryButton}"
                        Click="OnOkClick" Margin="0,0,15,0"/>
                <Button x:Name="CancelBtn" Content="且容我三思" Style="{StaticResource AppButton}"
                        Click="OnCancelClick"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
